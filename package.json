{
  "name": "typetype",
  "version": "0.3.5",
  "description": "typetype local voice input tool with offline ASR",
  "main": "dist-electron/main.js",
  "author": "typetype",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:electron && electron .",
    "build:electron": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "build:code-switch-lexicon": "node scripts/build_code_switch_lexicon.js",
    "build": "npm run build:electron && npm install sherpa-onnx-darwin-arm64 sherpa-onnx-darwin-x64 --no-save --force && electron-builder --mac",
    "build:mac": "npm run build:electron && npm install sherpa-onnx-darwin-arm64 sherpa-onnx-darwin-x64 --no-save --force && electron-builder --mac",
    "build:win": "npm run build:electron && npm install sherpa-onnx-win-x64 --no-save --force && electron-builder --win --x64"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.3",
    "@huggingface/transformers": "^4.2.0",
    "@iarna/toml": "^2.2.5",
    "bzip2": "^0.1.1",
    "mammoth": "^1.12.0",
    "onnxruntime-node": "1.23.2",
    "sherpa-onnx-node": "^1.12.39",
    "tar-stream": "^3.2.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "onnxruntime-node": "1.23.2"
  },
  "pnpm": {
    "overrides": {
      "onnxruntime-node": "1.23.2"
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "app.typetype",
    "productName": "typetype",
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "node_modules/sherpa-onnx-node/**/*",
      "node_modules/sherpa-onnx-darwin-arm64/**/*",
      "node_modules/sherpa-onnx-darwin-x64/**/*",
      "node_modules/onnxruntime-node/**/*"
    ],
    "files": [
      "src/**/*",
      "dist/**/*",
      "dist-electron/**/*",
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*",
          "!models/**",
          "!punctuation-models/**",
          "!translation-models/**",
          "!runtimes/**"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "resources/models",
        "to": "models",
        "filter": [
          "**/*",
          "!**/README.md",
          "!**/test_wavs",
          "!**/test_wavs/**"
        ]
      },
      {
        "from": "resources/punctuation-models",
        "to": "punctuation-models",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/translation-models",
        "to": "translation-models",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.icns",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "此应用需要访问您的麦克风以录制语音进行离线听写输入。"
      }
    }
  }
}
